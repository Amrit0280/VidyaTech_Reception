  "private": true,
  "type": "module",
  "description": "Premium school technology business website and multi-role school management software ecosystem.",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host 0.0.0.0",
